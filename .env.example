# Copy to .env before running docker compose

NEKOHUB_IMAGE=ghcr.io/fengying1314/nekohub:latest
ASPNETCORE_URLS=http://+:8080

# PostgreSQL
POSTGRES_DB=nekohub
POSTGRES_USER=nekohub
POSTGRES_PASSWORD=nekohub-dev
POSTGRES_PORT=5432
Persistence__Database__Provider=postgresql
Persistence__Database__ConnectionString=Host=postgres;Port=5432;Database=nekohub;Username=nekohub;Password=nekohub-dev;Pooling=true

# JWT auth for browser admin console
Auth__Jwt__Issuer=NekoHub
Auth__Jwt__Audience=NekoHub.Admin
Auth__Jwt__Secret=please-set-a-strong-jwt-secret-at-least-32-chars
Auth__Jwt__AccessTokenMinutes=15
Auth__Jwt__RefreshTokenDays=30

# First deployment only: creates a SuperAdmin only when there are no users
Auth__BootstrapSuperAdmin__Username=replace-with-bootstrap-admin-username
Auth__BootstrapSuperAdmin__Password=replace-with-bootstrap-admin-password

# Optional: keep API key enabled for MCP / scripts / old integrations
Auth__ApiKey__Enabled=false
Auth__ApiKey__Keys__0=

# Frontend
FRONTEND_PORT=5173

# Split-origin deployment example:
# FRONTEND_VITE_API_BASE_URL=https://api.example.com
FRONTEND_VITE_API_BASE_URL=http://localhost:5121

# If you serve frontend and API from the same origin through a reverse proxy, this can be empty
# FRONTEND_VITE_API_BASE_URL=

FRONTEND_VITE_MAX_UPLOAD_SIZE_BYTES=10485760

# Local storage mode
Storage__Provider=local
Storage__Local__RootPath=/app/storage/assets
Storage__PublicBaseUrl=http://localhost:5121/content

# S3-compatible mode
# Storage__Provider=s3
# Storage__S3__ProviderName=s3
# Storage__S3__Endpoint=http://minio:9000
# Storage__S3__Bucket=nekohub
# Storage__S3__Region=us-east-1
# Storage__S3__AccessKey=minioadmin
# Storage__S3__SecretKey=minioadmin
# Storage__S3__ForcePathStyle=true
# Storage__S3__PublicBaseUrl=http://localhost:9000/nekohub

# GitHub repo mode (experimental)
# Storage__Provider=github-repo
# Storage__GitHubRepo__ProviderName=github-repo
# Storage__GitHubRepo__Owner=your-org
# Storage__GitHubRepo__Repo=your-repo
# Storage__GitHubRepo__Ref=main
# Storage__GitHubRepo__BasePath=assets/images
# Storage__GitHubRepo__ApiBaseUrl=https://api.github.com
# Storage__GitHubRepo__RawBaseUrl=https://raw.githubusercontent.com
# Storage__GitHubRepo__VisibilityPolicy=public-only
# Storage__GitHubRepo__Token=
# Storage__GitHubRepo__CommitMessageTemplate=chore(nekohub): {operation} {path}

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
