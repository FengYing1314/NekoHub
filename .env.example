# NekoHub environment example
# 使用方式：
# 1) cp .env.example .env
# 2) 修改 Auth__ApiKey__Keys__0
# 3) docker compose up -d

# ============================================================
# Common
# ============================================================
NEKOHUB_IMAGE=ghcr.io/fengying1314/nekohub:latest
ASPNETCORE_URLS=http://+:8080
Persistence__Database__Provider=sqlite
Persistence__Database__ConnectionString=Data Source=/app/storage/nekohub.db

Auth__ApiKey__Enabled=true
Auth__ApiKey__Keys__0=change-this-api-key-in-production

# ============================================================
# Frontend (web/nekohub-web)
# ============================================================
# 对外前端端口（容器 4173 -> 宿主 FRONTEND_PORT）
FRONTEND_PORT=5173
# 前端默认 API Base URL（前后端分离，浏览器直连后端公开地址）
FRONTEND_VITE_API_BASE_URL=http://localhost:5121
# 前端上传前置大小校验（需与后端 MaxUploadSizeBytes 一致）
FRONTEND_VITE_MAX_UPLOAD_SIZE_BYTES=10485760

# ============================================================
# Local mode (默认最简体验)
# ============================================================
Storage__Provider=local
Storage__Local__RootPath=/app/storage/assets
Storage__PublicBaseUrl=http://localhost:5121/content

# ============================================================
# S3-compatible mode (配合 compose --profile s3)
# 如果启用 S3，请取消注释并按需修改
# ============================================================
# Storage__Provider=s3
# Storage__S3__ProviderName=s3
# Storage__S3__Endpoint=http://minio:9000
# Storage__S3__Bucket=nekohub
# Storage__S3__Region=us-east-1
# Storage__S3__AccessKey=minioadmin
# Storage__S3__SecretKey=minioadmin
# Storage__S3__ForcePathStyle=true
# Storage__S3__PublicBaseUrl=http://localhost:9000/nekohub

# ============================================================
# MinIO bootstrap (compose s3 profile)
# ============================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
