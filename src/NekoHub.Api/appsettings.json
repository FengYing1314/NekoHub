{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Api": {
    "Assets": {
      "MaxUploadSizeBytes": 10485760,
      "AllowedContentTypes": [ "image/jpeg", "image/png", "image/webp", "image/gif" ],
      "DefaultPageSize": 20,
      "MaxPageSize": 100
    }
  },
  "Auth": {
    "ApiKey": {
      "Enabled": false,
      "Keys": []
    },
    "Jwt": {
      "Issuer": "NekoHub",
      "Audience": "NekoHub.Admin",
      "Secret": "",
      "AccessTokenMinutes": 15,
      "RefreshTokenDays": 30
    },
    "BootstrapSuperAdmin": {
      "Username": "",
      "Password": ""
    }
  },
  "Storage": {
    "Provider": "local",
    "PublicBaseUrl": "http://localhost:5121/content",
    "Local": {
      "RootPath": "storage/assets",
      "CreateDirectoryIfMissing": true
    },
    "S3": {
      "ProviderName": "s3",
      "Endpoint": "https://s3.amazonaws.com",
      "Bucket": "",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "ForcePathStyle": false,
      "PublicBaseUrl": ""
    },
    "GitHubRepo": {
      "ProviderName": "github-repo",
      "Owner": "",
      "Repo": "",
      "Ref": "main",
      "BasePath": "",
      "ApiBaseUrl": "https://api.github.com",
      "RawBaseUrl": "https://raw.githubusercontent.com",
      "VisibilityPolicy": "public-only",
      "Token": "",
      "CommitMessageTemplate": "chore(nekohub): {operation} {path}"
    }
  },
  "Persistence": {
    "Database": {
      "Provider": "postgresql",
      "ConnectionString": "Host=localhost;Port=5432;Database=nekohub;Username=nekohub;Password=nekohub-dev;Pooling=true"
    }
  },
  "Security": {
    "DataProtection": {
      "KeysPath": "storage/keys"
    }
  },
  "AllowedHosts": "*"
}
