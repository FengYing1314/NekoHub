{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Api": {
    "Assets": {
      "MaxUploadSizeBytes": 10485760,
      "AllowedContentTypes": [ "image/jpeg", "image/png", "image/webp", "image/gif" ],
      "DefaultPageSize": 20,
      "MaxPageSize": 100
    }
  },
  "Auth": {
    "ApiKey": {
      "Enabled": true,
      "Keys": [ "change-this-api-key-in-production" ]
    }
  },
  "Storage": {
    "Provider": "local",
    "PublicBaseUrl": "http://localhost:5121/content",
    "Local": {
      "RootPath": "storage/assets",
      "CreateDirectoryIfMissing": true
    },
    "S3": {
      "ProviderName": "s3",
      "Endpoint": "https://s3.amazonaws.com",
      "Bucket": "",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "ForcePathStyle": false,
      "PublicBaseUrl": ""
    }
  },
  "Persistence": {
    "Database": {
      "Provider": "sqlite",
      "ConnectionString": "Data Source=storage/nekohub.db"
    }
  },
  "AllowedHosts": "*"
}
