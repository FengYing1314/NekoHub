  "keyFeatures": [
    "Public gallery for anonymous browsing of published image assets",
    "JWT-secured admin console for full asset lifecycle management",
    "Multi-provider storage support: local disk, S3-compatible, and GitHub repos",
    "AI-powered asset enrichment via configurable AI provider profiles",
    "MCP (Model Context Protocol) endpoint for AI agent integrations",
    "Role-based access control with granular permissions per user",
    "API key compatibility for scripts, automation, and legacy integrations",
    "Image upload with validation, metadata, alt text, and public/private visibility"
  ],
  "publicApiSurface": [
